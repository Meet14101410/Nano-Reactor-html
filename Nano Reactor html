<!DOCTYPE html>
<html>
<head>
  <title>Nano Reactor</title>
  <style>
    body{
      background:black;
      color:lime;
      text-align:center;
      font-family:Arial;
    }
    button{
      padding:10px 20px;
      font-size:20px;
      margin-top:20px;
    }
  </style>
</head>
<body>

<h1>Nano Reactor</h1>
<p>Energy Level: <span id="energy">0</span></p>

<button onclick="reactor()">Generate Energy</button>

<script>
let energy = 0;

function reactor(){
  energy += 10;
  document.getElementById("energy").innerText = energy;
}
</script>

</body>
</html>
